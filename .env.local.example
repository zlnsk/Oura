# Google OAuth (for Gmail login — open to all Google accounts)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-generate-with-openssl-rand-base64-32

# Anthropic API Key (for AI summaries — optional, enables AI health insights)
# If not set, the AI summary feature will be hidden
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: limit AI summaries per user per day (default: 5)
AI_SUMMARY_DAILY_LIMIT=5
